params {
    ground_truth = "${projectDir}/assets/ground_truth.tsv"
    n_pos        = 50
    n_neg        = 50
    seed         = 42
    field_map           = null  // e.g. 'organism_scientific_name:organism,platform_gpl_accession:platform'
    jaccard_fields      = 'tf_name'  // comma-separated fields to score with Jaccard instead of exact match
    screening_truth_col = 'has_perturbation'
    outdir       = 'results'
    biolit_config = 'config.json'
}

profiles {
    conda {
        conda.enabled = true
        process.conda   = "${projectDir}/environment.yml"
    }
}
